<Window x:Class="DesktopPlanWidget.EditPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="计划管理[开发：青岩 微信：qingyan_lml]" Width="800" Height="500" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- 水印样式：纯 XAML，无后台代码 -->
        <Style x:Key="WatermarkStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- 文本框原有内容区域 -->
                            <ScrollViewer x:Name="PART_ContentHost" />
                            <!-- 水印文字（通过 DataTrigger 控制显示/隐藏） -->
                            <TextBlock Text="我的农历生日，选按年（农历）" 
                                       Foreground="Gray" 
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <!-- 当 TextBox 的 Text 为空字符串时显示水印 -->
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 0 10 0" Height="52">
                <DatePicker x:Name="dp" Width="130" Height="52" VerticalContentAlignment="Center" />
                <ComboBox x:Name="cbTime" Width="90" Height="52" Margin="5 0 0 0" VerticalContentAlignment="Center" />
                <TextBox x:Name="txt" Style="{StaticResource WatermarkStyle}"  Width="260" Height="52" Margin="5 0 0 0" VerticalContentAlignment="Center" />
                <ComboBox x:Name="cbo" Width="110" Height="52" Margin="5 0 0 0" SelectedIndex="0" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="不重复"/>
                    <ComboBoxItem Content="按天重复"/>
                    <ComboBoxItem Content="按周重复"/>
                    <ComboBoxItem Content="按月重复"/>
                    <ComboBoxItem Content="按年重复"/>
                    <ComboBoxItem Content="按年(农历)"/>
                </ComboBox>
                <TextBox x:Name="interval" Width="60" Height="52" Margin="5 0 0 0" Text="1" VerticalContentAlignment="Center" />
                <Button x:Name="btnAdd" Content="添加计划" Width="80" Height="52" Margin="5 0 0 0" Click="Add"/>
                <Button x:Name="btnUpdate" Content="保存修改" Width="80" Height="52" Margin="5 0 0 0" Click="Update" Background="#0063b1" Foreground="White"/>
            </StackPanel>

            <ListBox x:Name="list" Height="400" Margin="0 5 0 0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0 2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding PlanDate,StringFormat=yyyy-MM-dd HH:mm}" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Content}" Grid.Column="1" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding RepeatDesc}" Grid.Column="2" VerticalAlignment="Center" Foreground="LightBlue"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="修改" Width="38" Background="#369" Foreground="White" Click="LoadToEdit"/>
                                <Button Content="删除" Width="38" Margin="2 0 0 0" Background="#c83c3c" Foreground="White" Click="Del"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>