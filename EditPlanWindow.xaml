<Window x:Class="DesktopPlanWidget.EditPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="计划管理[作者:青岩，微信：qingyan_lml]" Width="700" Height="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <StackPanel>
            <Grid Margin="0 0 10 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <DatePicker x:Name="dp" Grid.Column="0" Height="25"/>
                <TextBox x:Name="txt" Grid.Column="1" Height="25" Margin="5 0 0 0"/>
                <ComboBox x:Name="cbo" Grid.Column="2" Height="25" Margin="5 0 0 0" SelectedIndex="0">
                    <ComboBoxItem Content="不重复"/>
                    <ComboBoxItem Content="按天重复"/>
                    <ComboBoxItem Content="按周重复"/>
                    <ComboBoxItem Content="按月重复"/>
                    <ComboBoxItem Content="按季度重复"/>
                    <ComboBoxItem Content="按年重复"/>
                    <ComboBoxItem Content="按年(农历)"/>
                </ComboBox>
                <TextBox x:Name="interval" Grid.Column="3" Text="1" Height="25" Margin="5 0 0 0"/>
                <Button x:Name="btnAdd" Grid.Column="4" Content="添加计划" Height="25" Margin="5 0 0 0" Click="Add"/>
            </Grid>

            <ListBox x:Name="list" Height="420">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0 1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="350"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PlanDate,StringFormat=yyyy-MM-dd}" Grid.Column="0" Foreground="#333"/>
                            <TextBlock Text="{Binding Content}" Grid.Column="1" Foreground="#222"/>
                            <Button Content="删除" Grid.Column="2" Background="#c83c3c" Foreground="White" Click="Del" Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>