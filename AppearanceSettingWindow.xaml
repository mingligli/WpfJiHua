<Window x:Class="DesktopPlanWidget.AppearanceSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="外观设置" Width="320" Height="260"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <DockPanel Margin="0,0,0,15">
                <TextBlock Text="标题颜色：" Width="80" VerticalAlignment="Center"/>
                <Button x:Name="btnTitle" Width="80" Height="28" BorderBrush="#999"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,15">
                <TextBlock Text="日期颜色：" Width="80" VerticalAlignment="Center"/>
                <Button x:Name="btnDate" Width="80" Height="28" BorderBrush="#999"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="内容颜色：" Width="80" VerticalAlignment="Center"/>
                <Button x:Name="btnContent" Width="80" Height="28" BorderBrush="#999"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="保存" Width="75"/>
                <Button x:Name="btnReset" Content="默认" Width="75"/>
                <Button x:Name="btnClose" Content="关闭" Width="75"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>